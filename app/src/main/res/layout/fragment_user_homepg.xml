<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserHomePgFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <Button
            android:id="@+id/btGoToAllUserHomePgFragment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="280dp"
            android:text="go to all pieces"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="MissingConstraints" />

        <Button
            android:id="@+id/btGoToAddUserHomePgFragmint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="114dp"
            android:text="go to add pieces"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btGoToAllUserHomePgFragment"
            tools:ignore="MissingConstraints" />

        <Button
            android:id="@+id/btSignOutUserHomePgFragmint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:layout_marginEnd="24dp"
            android:text="Sign Out"
            app:layout_constraintEnd_toEndOf="@+id/btGoToAddUserHomePgFragmint"
            app:layout_constraintTop_toBottomOf="@+id/btGoToAddUserHomePgFragmint" />

        <Button
            android:id="@+id/btEditDetailsUserHomePgFragmint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Details"
            tools:layout_editor_absoluteX="145dp"
            tools:layout_editor_absoluteY="196dp"
            tools:ignore="MissingConstraints" />

        <Button
            android:id="@+id/btDeleteAccountUserHomePgFragment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF4444"
            android:text="Delete My Account"
            tools:layout_editor_absoluteX="217dp"
            tools:layout_editor_absoluteY="26dp"
            tools:ignore="MissingConstraints" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>