<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FAF9F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#684D45"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layoutDirection="ltr"
        android:padding="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Art Gallery"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSearchToggle"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#FFFFFF" />

        <Button
            android:id="@+id/btnHomeAllPiecesFragment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:icon="@android:drawable/ic_menu_myplaces"
            app:iconTint="#FFFFFF"
            app:iconSize="24dp"
            app:iconPadding="0dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:gravity="center"
            android:text="" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllPiecesFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"/>
        </ScrollView>

        <LinearLayout
            android:id="@+id/searchLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#F0EBE8"
            android:elevation="10dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <EditText
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Search masterpieces..."
                android:background="@android:drawable/editbox_background_normal"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/minPrice"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:hint="Min"
                    android:inputType="numberDecimal"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/maxPrice"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:hint="Max"
                    android:inputType="numberDecimal"
                    android:layout_marginEnd="4dp" />

                <Spinner android:id="@+id/categorySpinner" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:layout_marginEnd="4dp"/>
                <Spinner android:id="@+id/sizeSpinner" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#684D45"
                android:text="Apply Filter"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>