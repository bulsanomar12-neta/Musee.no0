<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white"
                android:elevation="5dp"
                android:clipToPadding="false"
                android:clipToOutline="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- الصورة -->
                <ImageView
                    android:id="@+id/imgPieceDetails"
                    android:layout_width="match_parent"
                    android:layout_height="380dp"
                    android:adjustViewBounds="true"
                    android:background="#DDDDDD"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true" />

                <!-- Art Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Art Name"
                    android:textColor="#777"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvArtNamePieceDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Art Name"
                    android:textColor="#000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Size -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Size"
                    android:textColor="#777"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSizePieceDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Size"
                    android:textColor="#444"
                    android:textSize="16sp" />

                <!-- Price -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Price"
                    android:textColor="#777"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvPricePieceDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="#0A7F2E"
                    android:text="Price"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <!-- Information -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Information"
                    android:textColor="#777"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvInformationPieceDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Information"
                    android:textColor="#222"
                    android:textSize="16sp" />

                <!-- Artist / Hours / Category -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="26dp"
                    android:weightSum="3">

                    <!-- Artist -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Artist"
                            android:textColor="#777"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvArtistNamePieceDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Artist Name"
                            android:textColor="#444"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hours"
                            android:textColor="#777"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvHoursPieceDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hours"
                            android:textColor="#444"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Category -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textColor="#777"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvCategoryPieceDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            android:textColor="#444"
                            android:textSize="16sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btSMSDetails"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="#6F7F8F"
                        android:text="SMS" />

                    <Space
                        android:layout_width="16dp"
                        android:layout_height="wrap_content" />

                    <Button
                        android:id="@+id/btEmailDetails"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="#6F559E"
                        android:text="Email" />
                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</FrameLayout>
