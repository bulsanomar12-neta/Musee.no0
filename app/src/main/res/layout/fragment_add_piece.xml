<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    tools:context=".AddPieceFragment">

    <View
        android:id="@+id/topHeaderAddPiece"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#4E342E"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackAddPieceFragment"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Publish Artwork"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBackAddPieceFragment"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackAddPieceFragment" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHeaderAddPiece"
        android:layout_marginTop="-40dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artwork Details"
                    android:textColor="#4E342E"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etNameAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Artwork Name"
                    android:paddingHorizontal="12dp"
                    android:textSize="15sp" />

                <Spinner
                    android:id="@+id/spCategoryAddPiece"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    android:entries="@array/types_array" />

                <EditText
                    android:id="@+id/etArtistAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Artist Name"
                    android:paddingHorizontal="12dp"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etHoursAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Duration (Hours)"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textSize="15sp" />

                <Spinner
                    android:id="@+id/etSizeAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    android:entries="@array/types_array_size" />

                <EditText
                    android:id="@+id/etInformationAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="top"
                    android:hint="Describe your masterpiece..."
                    android:minHeight="100dp"
                    android:padding="12dp"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etPriceAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="#EFEBE9"
                    android:hint="Price (USD $)"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textColor="#5D4037"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvImageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Image"
                android:layout_marginTop="24dp"
                android:textColor="#4E342E"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardContainer"/>

            <ImageView
                android:id="@+id/imgPieceItem"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="8dp"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvImageLabel"
                app:srcCompat="@android:drawable/ic_menu_camera" />

            <Button
                android:id="@+id/btAddPieceFragment"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:backgroundTint="#4E342E"
                android:text="PUBLISH ARTWORK"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imgPieceItem" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>